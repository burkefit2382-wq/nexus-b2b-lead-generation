{
  "name": "nexus-b2b-lead-generation",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "setup:frontend": "npm --prefix frontend install",
    "setup:backend": "python -m pip install -r backend/requirements-dev.txt",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:backend": "uvicorn backend.app.main:app --host 0.0.0.0 --port ${API_PORT:-8000} --reload",
    "build": "npm --prefix frontend install && npm --prefix frontend run build && python -m pip install -r backend/requirements.txt",
    "test": "PYTHONPATH=. python -m pytest backend/tests",
    "wrangler:login": "wrangler login",
    "cf:deploy": "wrangler deploy",
    "launch:deploy": "npm run build && azd up --no-prompt && npm run cf:deploy"
  },
  "devDependencies": {
    "wrangler": "^4.104.0"
  }
}
