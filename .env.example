# Frontend
VITE_API_BASE_URL=http://localhost:8000

# Backend
API_PORT=8000
CORS_ORIGINS=http://localhost:5173
NODE_ENV=development
API_BASE_URL=http://localhost:8000

# Neon Postgres (never commit real credentials)
DATABASE_URL_DEV=postgresql://<user>:<password>@<dev-host>.neon.tech/neondb?sslmode=require&channel_binding=require
DATABASE_URL_STG=postgresql://<user>:<password>@<stg-host>.neon.tech/neondb?sslmode=require&channel_binding=require
DATABASE_URL_PROD=postgresql://<user>:<password>@<prod-host>.neon.tech/neondb?sslmode=require&channel_binding=require

# Runtime secrets
JWT_SECRET=replace_with_strong_secret
REDIS_URL=redis://localhost:6379/0
