# =============================================================================
# Nexus B2B Lead Generation – Environment Variables
# Copy this file to .env (never commit .env) and fill in real values.
# =============================================================================

# ---------------------------------------------------------------------------
# Frontend
# ---------------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# Backend – Server
# ---------------------------------------------------------------------------
API_PORT=8000
CORS_ORIGINS=http://localhost:5173
NODE_ENV=development
TRACKING_ALLOWED_ORIGIN=*

# ---------------------------------------------------------------------------
# Database – Neon Postgres (use separate branches per environment)
# Format: ******host/dbname?sslmode=require&channel_binding=require
# ---------------------------------------------------------------------------
DATABASE_URL=******...neon.tech/neondb?sslmode=require&channel_binding=require
DATABASE_URL_DEV=******...neon.tech/neondb?sslmode=require&channel_binding=require
DATABASE_URL_STG=******...neon.tech/neondb?sslmode=require&channel_binding=require
DATABASE_URL_PROD=******...neon.tech/neondb?sslmode=require&channel_binding=require

# ---------------------------------------------------------------------------
# Auth & Security
# ---------------------------------------------------------------------------
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# ---------------------------------------------------------------------------
# Cache (optional – set if using Redis)
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# ---------------------------------------------------------------------------
# Email – Resend
# ---------------------------------------------------------------------------
RESEND_API_KEY=re_xxxxxxxxx
RESEND_FROM=NEXUS <no-reply@mail.nexuscloud.sh>
EMAIL_DOMAIN=mail.nexuscloud.sh
WAITLIST_NOTIFY_TO=you@yourdomain.com

# ---------------------------------------------------------------------------
# Payments – Stripe
# ---------------------------------------------------------------------------
STRIPE_API_VERSION=2026-06-24.dahlia
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
PRICE_ID=price_starter_350

# ---------------------------------------------------------------------------
# Storage – Cloudflare R2
# ---------------------------------------------------------------------------
R2_ACCESS_KEY=your_r2_access_key
R2_SECRET_KEY=your_r2_secret_key
R2_BUCKET=nexus-leads
R2_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com

# ---------------------------------------------------------------------------
# AI / LLM (local Ollama or remote endpoint)
# ---------------------------------------------------------------------------
LLAMA_CHAT_ENDPOINT=http://127.0.0.1:11434/api/chat
LLAMA_CHAT_MODEL=llama3

# ---------------------------------------------------------------------------
# Launch site
# ---------------------------------------------------------------------------
LAUNCH_HOST=127.0.0.1
LAUNCH_PORT=4173
PUBLIC_BASE_URL=https://nexuscloud.sh

# ---------------------------------------------------------------------------
# Render Deployment (store as GitHub Secrets, not in .env)
# RENDER_API_KEY          – Render account API key
# RENDER_STG_SERVICE_ID   – Render staging backend service ID (e.g. srv-...)
# RENDER_PROD_SERVICE_ID  – Render production backend service ID
# RENDER_STG_FRONTEND_SERVICE_ID  – Render staging frontend service ID
# RENDER_PROD_FRONTEND_SERVICE_ID – Render production frontend service ID
# ---------------------------------------------------------------------------
# RENDER_API_KEY=rnd_xxxxxxxxxxxxxxxxxxxx        # GitHub Secret
# RENDER_STG_SERVICE_ID=srv-xxxxxxxxxxxx         # GitHub Secret
# RENDER_PROD_SERVICE_ID=srv-xxxxxxxxxxxx        # GitHub Secret

# ---------------------------------------------------------------------------
# Neon (store as GitHub Secrets / Render env vars)
# NEON_PROJECT_ID – used by neon-preview-branches workflow
# NEON_API_KEY    – used by neon-preview-branches workflow
# ---------------------------------------------------------------------------
# NEON_PROJECT_ID=your-neon-project-id           # GitHub Variable (not secret)
# NEON_API_KEY=neon_xxxxxxxxxxxxxxxxxxxx          # GitHub Secret
