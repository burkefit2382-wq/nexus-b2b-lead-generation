# Frontend
VITE_API_BASE_URL=http://localhost:8000

# Backend
API_PORT=8000
CORS_ORIGINS=http://localhost:5173

# Neon Postgres – per-environment connection strings
# Format: ******<host>.neon.tech/dbname?sslmode=require&channel_binding=require
DATABASE_URL_DEV=******ep-xxx-dev.us-east-2.aws.neon.tech/neondb?sslmode=require&channel_binding=require
DATABASE_URL_STG=******ep-xxx-stg.us-east-2.aws.neon.tech/neondb?sslmode=require&channel_binding=require
DATABASE_URL_PROD=******ep-xxx-prod.us-east-2.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Active connection string used by the backend at runtime.
# Set this to one of the values above depending on the environment.
DATABASE_URL=******ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Cloudflare R2 object storage
R2_ACCESS_KEY=your_r2_access_key
R2_SECRET_KEY=your_r2_secret_key
R2_BUCKET=your_r2_bucket_name
R2_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com

# Auth / security
JWT_SECRET=replace_with_a_long_random_secret

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM=Nexus <sales@nexuscloud.sh>
WAITLIST_NOTIFY_TO=you@example.com

# Public site URL (Render / custom domain)
PUBLIC_BASE_URL=https://nexuscloud.sh
LAUNCH_HOST=0.0.0.0

# Stripe
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
STRIPE_API_VERSION=2026-06-24.dahlia
PRICE_ID=

# Render deployment (used by GitHub Actions deploy workflow)
RENDER_API_KEY=rnd_xxxxxxxxxxxxxxxxxxxx
RENDER_STG_SERVICE_ID=srv_xxxxxxxxxxxxxxxxxxxx
RENDER_PROD_SERVICE_ID=srv_xxxxxxxxxxxxxxxxxxxx

# Neon (used by GitHub Actions preview-branch workflow)
NEON_API_KEY=your_neon_api_key
NEON_PROJECT_ID=your_neon_project_id
