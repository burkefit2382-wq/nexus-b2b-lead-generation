# Copy this file to .env on the server.
# Never commit the real .env file.

APP_MODULE=app.main:app
ENVIRONMENT=production
SECRET_KEY=replace-with-a-long-random-secret
DATABASE_URL=postgresql+psycopg://user:password@db-host:5432/nexuscloud

EMERGENT_API_KEY=replace-with-emergent-key
WORKER_ENABLED=false
WORKER_COMMAND=python -m app.worker

CORS_ORIGINS=https://nexuscloud.ai,https://www.nexuscloud.ai

# Optional provider keys.
OPENAI_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
